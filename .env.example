# AlphaVest WealthOS local development.

APP_ENV=local
NEXT_PUBLIC_APP_NAME="AlphaVest WealthOS"

# PostgreSQL / Prisma local database.
DATABASE_URL="postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@localhost:5432/alphavest_wealthos?schema=public"
POSTGRES_DB="alphavest_wealthos"
POSTGRES_USER="CHANGE_ME"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_PORT=5432

# Prisma Studio defaults.
PRISMA_STUDIO_PORT=5555
