# AlphaVest WealthOS local development.

APP_ENV=local
NEXT_PUBLIC_APP_NAME="AlphaVest WealthOS"
ALPHAVEST_DATA_MODE=demo
ALPHAVEST_REAL_CLIENT_DATA_ALLOWED=false
ALPHAVEST_PILOT_RELEASE_STAGE=local_demo
ALPHAVEST_DEMO_STORAGE_ROOT=tmp/demo-document-storage
ALPHAVEST_OBJECT_STORAGE_DRIVER=local
ALPHAVEST_S3_ACCESS_KEY_ID=alphavest
ALPHAVEST_S3_BUCKET=alphavest-documents
ALPHAVEST_S3_ENDPOINT=http://127.0.0.1:9000
ALPHAVEST_S3_REGION=us-east-1
ALPHAVEST_S3_SECRET_ACCESS_KEY=alphavest-local-secret

# Optional local S3-compatible object storage for Docker Compose.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=alphavest
MINIO_ROOT_PASSWORD=alphavest-local-secret

# PostgreSQL / Prisma local database.
DATABASE_URL="postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@localhost:5432/alphavest_wealthos?schema=public"
POSTGRES_DB="alphavest_wealthos"
POSTGRES_USER="CHANGE_ME"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_PORT=5432

# Prisma Studio defaults.
PRISMA_STUDIO_PORT=5555
