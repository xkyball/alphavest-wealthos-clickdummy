services:
  postgres:
    image: postgres:17-alpine
    container_name: alphavest-wealthos-postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-alphavest_wealthos}
      POSTGRES_USER: ${POSTGRES_USER:-alphavest}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-alphavest}
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 5s
      timeout: 3s
      retries: 12
      start_period: 5s
    volumes:
      - alphavest_postgres_data:/var/lib/postgresql/data

volumes:
  alphavest_postgres_data:

