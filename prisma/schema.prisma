// AlphaVest WealthOS — Phase 03 Prisma data model.
// This is an MVP implementation schema guided by docs/v3/DATA_MODEL_V3.md.
// Wide cross-object concepts use targetType/targetId to avoid brittle polymorphic relations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  DRAFT
  ONBOARDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  LOCKED
  ARCHIVED
}

enum RoleScope {
  PLATFORM
  TENANT
  ENTITY
  ENGAGEMENT
  DOCUMENT
  DECISION
}

enum ObjectType {
  PLATFORM
  TENANT
  USER
  ROLE
  PERMISSION
  FAMILY_MEMBER
  RELATIONSHIP
  ENGAGEMENT
  ENTITY
  ASSET
  DOCUMENT
  TRIGGER
  ACTION_ITEM
  RECOMMENDATION
  DECISION
  EVIDENCE_RECORD
  AUDIT_EVENT
  EXPORT_REQUEST
  JOURNEY
  JOURNEY_STEP
  PROCESS
  PROCESS_STEP
  MESSAGE
  REVIEW_SCHEDULE
  POLICY
  QUEUE_ITEM
  DATA_QUALITY_ISSUE
}

enum PermissionAction {
  VIEW
  CREATE
  EDIT
  DELETE
  UPLOAD
  REVIEW
  APPROVE
  RELEASE
  BLOCK
  EXPORT
  INVITE
  ASSIGN
  REVOKE
  COMMENT
  SCHEDULE
  ESCALATE
  MANAGE
}

enum Sensitivity {
  PUBLIC
  CLIENT_VISIBLE
  CONFIDENTIAL
  RESTRICTED
  HIGHLY_RESTRICTED
  INTERNAL_ONLY
}

enum VisibilityStatus {
  INTERNAL_ONLY
  ADVISOR_VISIBLE
  COMPLIANCE_VISIBLE
  CLIENT_VISIBLE
  RESTRICTED
  REDACTED
}

enum WorkflowStatus {
  DRAFT
  NEW
  IN_REVIEW
  AWAITING_INFO
  ANALYST_REVIEW
  ADVISOR_REVIEW
  COMPLIANCE_PENDING
  READY_FOR_CLIENT
  CLIENT_VISIBLE
  COMPLETED
  DEFERRED
  BLOCKED
  REJECTED
  ARCHIVED
}

enum DocumentStatus {
  EMPTY
  UPLOADING
  UPLOADED
  AI_EXTRACTED
  CLIENT_CONFIRMED
  ANALYST_REVIEW_PENDING
  VERIFIED
  NEEDS_CLARIFICATION
  BLOCKED
  LINKED_TO_EVIDENCE
  ARCHIVED
}

enum ReviewStatus {
  NOT_STARTED
  PENDING
  IN_REVIEW
  APPROVED
  REVISED
  REJECTED
  REQUEST_MORE_DATA
  ESCALATED_TO_CALL
  COMPLETED
}

enum ComplianceStatus {
  NOT_REQUIRED
  PENDING
  IN_REVIEW
  RELEASED
  BLOCKED
  NEEDS_EVIDENCE
  EXCEPTION
  EXPIRED
}

enum AdviceClassification {
  INFORMATION
  WORKFLOW
  GUIDANCE
  ADVICE_RELEVANT
  ADVICE
  OUT_OF_SCOPE
}

enum RecommendationStatus {
  DRAFT
  AI_DRAFT
  ANALYST_REVIEWED
  ADVISOR_PENDING
  ADVISOR_APPROVED
  REVISION_REQUESTED
  MORE_DATA_REQUESTED
  COMPLIANCE_PENDING
  RELEASED_TO_CLIENT
  BLOCKED
  CLIENT_ACCEPTED
  CLIENT_DEFERRED
  CLIENT_REJECTED
  ARCHIVED
}

enum InternalDraftStatus {
  CREATED
  CLASSIFIED
  REVISION_REQUESTED
  REJECTED
  REBUILT_WITH_EVIDENCE
  ADVISOR_READY
  ARCHIVED
}

enum DraftClassificationKind {
  ADVICE_RELEVANT
  GUIDANCE
  INFORMATION
  OUT_OF_SCOPE
}

enum DraftRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UnsupportedClaimStatus {
  NEEDS_EVIDENCE
  RESOLVED
  WAIVED
}

enum DecisionStatus {
  DRAFT
  RELEASED_TO_CLIENT
  AWAITING_FAMILY_APPROVAL
  ACCEPTED
  DEFERRED
  REJECTED
  EVIDENCE_CREATED
  REVIEW_SCHEDULED
  ARCHIVED
}

enum EvidenceStatus {
  PLACEHOLDER
  CREATED
  LINKED
  VALIDATED
  RELEASED
  RESTRICTED
  ARCHIVED
  SUPERSEDED
}

enum ExportStatus {
  DRAFT
  SCOPE_SELECTED
  REDACTION_PENDING
  APPROVAL_REQUIRED
  APPROVED
  GENERATED
  DOWNLOADED
  EXPIRED
  REVOKED
  FAILED
}

enum CommunicationChannel {
  SECURE_MESSAGE
  EMAIL
  PHONE
  VIDEO
  IN_PERSON
  SYSTEM_NOTIFICATION
}

enum EscalationType {
  NONE
  REQUEST_DATA
  ADVISOR_CALL
  F2F_WORKSHOP
  EXTERNAL_SPECIALIST
  COMPLIANCE_ESCALATION
  SECURITY_PRIVACY_REVIEW
}

enum AuditResult {
  SUCCESS
  DENIED
  BLOCKED
  FAILED
  PENDING
  WARNING
}

enum EntityType {
  TRUST
  COMPANY
  FOUNDATION
  PARTNERSHIP
  INDIVIDUAL
  FAMILY_OFFICE
  OTHER
}

enum AssetType {
  PORTFOLIO
  BANK_ACCOUNT
  REAL_ESTATE
  INSURANCE_POLICY
  BUSINESS_INTEREST
  LIQUIDITY
  TAX_RESIDENCY
  OTHER
}

enum ExportType {
  CLIENT_DECISION_PACK
  EVIDENCE_PACKAGE
  COMPLIANCE_AUDIT_PACK
  EXTERNAL_ADVISOR_DATA_ROOM
  TENANT_DATA_INVENTORY
  USER_ACCESS_REPORT
  ACTIVITY_LOG_EXPORT
  PILOT_METRICS_EXPORT
}

enum JourneyDefinitionStatus {
  ACTIVE
  HOLD_LOCKED
  DEFERRED
}

enum JourneyInstanceStatus {
  CREATED
  ACTIVE
  BLOCKED
  COMPLETED
  CANCELLED
}

enum JourneyStepStatus {
  LOCKED
  READY
  ACTIVE
  BLOCKED
  COMPLETED
  SKIPPED
}

enum JourneyObjectLinkRole {
  PRIMARY_CONTEXT
  SUPPORTING_EVIDENCE
  RECOMMENDATION
  DECISION
  EXPORT
  AUDIT_REFERENCE
}

enum ProcessDefinitionStatus {
  ACTIVE
  BLOCKED
  DEFERRED
  RETIRED
}

enum ProcessInstanceStatus {
  CREATED
  ACTIVE
  BLOCKED
  COMPLETED
  CANCELLED
}

enum ProcessStepStatus {
  LOCKED
  READY
  ACTIVE
  BLOCKED
  COMPLETED
  SKIPPED
}

enum ProcessObjectLinkRole {
  PRIMARY_CONTEXT
  SUPPORTING_EVIDENCE
  RECOMMENDATION
  DECISION
  EXPORT
  AUDIT_REFERENCE
  SOURCE_OBJECT
}

enum EvidenceSufficiencyDecisionStatus {
  SUFFICIENT
  INSUFFICIENT
}

model PlatformTenant {
  id              String             @id @default(uuid()) @db.Uuid
  name            String             @db.VarChar(160)
  legalName       String?            @db.VarChar(220)
  status          TenantStatus       @default(DRAFT)
  defaultTimezone String             @default("Africa/Johannesburg") @db.VarChar(64)
  defaultLocale   String             @default("en-ZA") @db.VarChar(16)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  clientTenants   ClientTenant[]
  users           User[]
  roles           Role[]
  policies        PolicyDefinition[]
  auditEvents     AuditEvent[]

  @@map("platform_tenants")
}

model ClientTenant {
  id                           String                        @id @default(uuid()) @db.Uuid
  platformTenantId             String                        @db.Uuid
  platformTenant               PlatformTenant                @relation(fields: [platformTenantId], references: [id], onDelete: Restrict)
  displayName                  String                        @db.VarChar(180)
  legalName                    String?                       @db.VarChar(220)
  status                       TenantStatus                  @default(DRAFT)
  jurisdiction                 String?                       @db.VarChar(80)
  relationshipTier             String?                       @db.VarChar(80)
  primaryAdvisorUserId         String?                       @db.Uuid
  primaryAnalystUserId         String?                       @db.Uuid
  complianceOwnerUserId        String?                       @db.Uuid
  clientSuccessOwnerUserId     String?                       @db.Uuid
  policyProfileId              String?                       @db.Uuid
  dataRegion                   String?                       @db.VarChar(80)
  riskRating                   String?                       @db.VarChar(40)
  onboardingCompletedAt        DateTime?
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  userProfiles                 UserProfile[]
  roles                        Role[]
  userRoles                    UserRole[]
  accessRequests               AccessRequest[]
  secondConfirmations          SecondConfirmation[]
  consentRecords               ConsentRecord[]
  familyMembers                FamilyMember[]
  relationships                Relationship[]
  objectives                   ClientObjective[]
  engagements                  Engagement[]
  entities                     Entity[]
  entityParticipants           EntityParticipant[]
  assets                       Asset[]
  documents                    Document[]
  triggers                     Trigger[]
  actionItems                  ActionItem[]
  recommendations              Recommendation[]
  approvals                    Approval[]
  complianceReviews            ComplianceReview[]
  decisions                    Decision[]
  evidenceRecords              EvidenceRecord[]
  evidenceSufficiencyDecisions EvidenceSufficiencyDecision[]
  reviewSchedules              ReviewSchedule[]
  messageThreads               MessageThread[]
  callEvents                   CallEvent[]
  exportRequests               ExportRequest[]
  policies                     PolicyDefinition[]
  queueItems                   QueueItem[]
  dataQualityIssues            DataQualityIssue[]
  journeyInstances             JourneyInstance[]
  processInstances             ProcessInstance[]
  auditEvents                  AuditEvent[]
  internalDrafts               InternalDraft[]

  @@index([platformTenantId])
  @@index([status])
  @@map("client_tenants")
}

model User {
  id               String          @id @default(uuid()) @db.Uuid
  platformTenantId String          @db.Uuid
  platformTenant   PlatformTenant  @relation(fields: [platformTenantId], references: [id], onDelete: Restrict)
  email            String          @unique @db.VarChar(180)
  displayName      String          @db.VarChar(160)
  status           UserStatus      @default(INVITED)
  mfaEnabled       Boolean         @default(false)
  lastLoginAt      DateTime?
  preferredLocale  String?         @db.VarChar(16)
  timezone         String?         @db.VarChar(64)
  isServiceAccount Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  profiles         UserProfile[]
  userRoles        UserRole[]
  consentRecords   ConsentRecord[]
  familyMembers    FamilyMember[]

  @@index([platformTenantId])
  @@map("users")
}

model UserProfile {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @db.Uuid
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientTenantId     String?       @db.Uuid
  clientTenant       ClientTenant? @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  firstName          String?       @db.VarChar(80)
  lastName           String?       @db.VarChar(80)
  phone              String?       @db.VarChar(40)
  relationshipLabel  String?       @db.VarChar(80)
  countryOfResidence String?       @db.VarChar(80)
  dateOfBirth        DateTime?     @db.Date
  sensitivity        Sensitivity   @default(CONFIDENTIAL)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([clientTenantId])
  @@map("user_profiles")
}

model Role {
  id                         String           @id @default(uuid()) @db.Uuid
  platformTenantId           String           @db.Uuid
  platformTenant             PlatformTenant   @relation(fields: [platformTenantId], references: [id], onDelete: Restrict)
  clientTenantId             String?          @db.Uuid
  clientTenant               ClientTenant?    @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  key                        String           @db.VarChar(120)
  name                       String           @db.VarChar(100)
  description                String?          @db.Text
  scope                      RoleScope
  isSystemRole               Boolean          @default(true)
  requiresSecondConfirmation Boolean          @default(false)
  segregationGroup           String?          @db.VarChar(80)
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  userRoles                  UserRole[]
  rolePermissions            RolePermission[]

  @@unique([platformTenantId, clientTenantId, key])
  @@index([platformTenantId])
  @@index([clientTenantId])
  @@map("roles")
}

model Permission {
  id                         String           @id @default(uuid()) @db.Uuid
  key                        String           @unique @db.VarChar(160)
  objectType                 ObjectType
  action                     PermissionAction
  description                String?          @db.Text
  defaultSensitivityLimit    Sensitivity?
  requiresAudit              Boolean          @default(false)
  requiresSecondConfirmation Boolean          @default(false)
  requiresComplianceReview   Boolean          @default(false)
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  rolePermissions            RolePermission[]

  @@index([objectType, action])
  @@map("permissions")
}

model UserRole {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @db.Uuid
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId           String        @db.Uuid
  role             Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  clientTenantId   String?       @db.Uuid
  clientTenant     ClientTenant? @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  entityId         String?       @db.Uuid
  engagementId     String?       @db.Uuid
  objectType       ObjectType?
  objectId         String?       @db.Uuid
  status           String        @default("active") @db.VarChar(40)
  validFrom        DateTime?
  validUntil       DateTime?
  assignedByUserId String?       @db.Uuid
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
  @@index([roleId])
  @@index([clientTenantId])
  @@map("user_roles")
}

model RolePermission {
  id            String     @id @default(uuid()) @db.Uuid
  roleId        String     @db.Uuid
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId  String     @db.Uuid
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  effect        String     @default("allow") @db.VarChar(20)
  conditionJson Json?
  createdAt     DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model AccessRequest {
  id                 String           @id @default(uuid()) @db.Uuid
  clientTenantId     String           @db.Uuid
  clientTenant       ClientTenant     @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  requesterUserId    String           @db.Uuid
  targetUserId       String?          @db.Uuid
  objectType         ObjectType
  objectId           String           @db.Uuid
  requestedAction    PermissionAction
  reason             String           @db.Text
  status             WorkflowStatus
  reviewerUserId     String?          @db.Uuid
  complianceRequired Boolean          @default(false)
  decisionAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([clientTenantId, status])
  @@map("access_requests")
}

model SecondConfirmation {
  id                 String           @id @default(uuid()) @db.Uuid
  clientTenantId     String?          @db.Uuid
  clientTenant       ClientTenant?    @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  actorUserId        String           @db.Uuid
  targetObjectType   ObjectType
  targetObjectId     String           @db.Uuid
  action             PermissionAction
  confirmationPhrase String?          @db.VarChar(160)
  confirmedByUserId  String?          @db.Uuid
  status             String           @default("pending") @db.VarChar(40)
  expiresAt          DateTime?
  createdAt          DateTime         @default(now())
  confirmedAt        DateTime?

  @@index([clientTenantId, status])
  @@map("second_confirmations")
}

model ConsentRecord {
  id             String        @id @default(uuid()) @db.Uuid
  clientTenantId String?       @db.Uuid
  clientTenant   ClientTenant? @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  userId         String        @db.Uuid
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType    String        @db.VarChar(80)
  version        String        @db.VarChar(40)
  status         String        @db.VarChar(40)
  acceptedAt     DateTime?
  withdrawnAt    DateTime?
  source         String?       @db.VarChar(80)
  ipAddress      String?       @db.VarChar(64)
  createdAt      DateTime      @default(now())

  @@index([clientTenantId])
  @@index([userId])
  @@map("consent_records")
}

model Engagement {
  id               String           @id @default(uuid()) @db.Uuid
  clientTenantId   String           @db.Uuid
  clientTenant     ClientTenant     @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  name             String           @db.VarChar(180)
  type             String           @db.VarChar(80)
  status           WorkflowStatus
  ownerUserId      String           @db.Uuid
  advisorUserId    String?          @db.Uuid
  analystUserId    String?          @db.Uuid
  complianceUserId String?          @db.Uuid
  startDate        DateTime?        @db.Date
  targetEndDate    DateTime?        @db.Date
  closedAt         DateTime?
  sensitivity      Sensitivity
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  documents        Document[]
  triggers         Trigger[]
  actionItems      ActionItem[]
  recommendations  Recommendation[]
  evidenceRecords  EvidenceRecord[]
  messageThreads   MessageThread[]
  callEvents       CallEvent[]

  @@index([clientTenantId, status])
  @@map("engagements")
}

model FamilyMember {
  id               String            @id @default(uuid()) @db.Uuid
  clientTenantId   String            @db.Uuid
  clientTenant     ClientTenant      @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  userId           String?           @db.Uuid
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  displayName      String            @db.VarChar(160)
  relationshipType String            @db.VarChar(80)
  dateOfBirth      DateTime?         @db.Date
  taxResidency     String?           @db.VarChar(80)
  isPrincipal      Boolean           @default(false)
  sensitivity      Sensitivity
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  objectives       ClientObjective[]

  @@index([clientTenantId])
  @@map("family_members")
}

model Relationship {
  id               String       @id @default(uuid()) @db.Uuid
  clientTenantId   String       @db.Uuid
  clientTenant     ClientTenant @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  subjectType      ObjectType
  subjectId        String       @db.Uuid
  relationshipType String       @db.VarChar(80)
  objectType       ObjectType
  objectId         String       @db.Uuid
  startDate        DateTime?    @db.Date
  endDate          DateTime?    @db.Date
  confidence       Decimal?     @db.Decimal(5, 2)
  sourceDocumentId String?      @db.Uuid
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([clientTenantId])
  @@index([subjectType, subjectId])
  @@index([objectType, objectId])
  @@map("relationships")
}

model ClientObjective {
  id                  String         @id @default(uuid()) @db.Uuid
  clientTenantId      String         @db.Uuid
  clientTenant        ClientTenant   @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  ownerFamilyMemberId String?        @db.Uuid
  ownerFamilyMember   FamilyMember?  @relation(fields: [ownerFamilyMemberId], references: [id], onDelete: SetNull)
  category            String         @db.VarChar(80)
  title               String         @db.VarChar(160)
  description         String?        @db.Text
  priority            String?        @db.VarChar(40)
  timeHorizon         String?        @db.VarChar(80)
  status              WorkflowStatus
  sensitivity         Sensitivity
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([clientTenantId])
  @@map("client_objectives")
}

model Entity {
  id                 String              @id @default(uuid()) @db.Uuid
  clientTenantId     String              @db.Uuid
  clientTenant       ClientTenant        @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  entityType         EntityType
  name               String              @db.VarChar(180)
  jurisdiction       String?             @db.VarChar(80)
  registrationNumber String?             @db.VarChar(120)
  status             String              @db.VarChar(40)
  ownerSummary       String?             @db.Text
  riskRating         String?             @db.VarChar(40)
  dataQualityScore   Int?
  sensitivity        Sensitivity
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  participants       EntityParticipant[]
  assets             Asset[]

  @@index([clientTenantId])
  @@map("entities")
}

model EntityParticipant {
  id               String       @id @default(uuid()) @db.Uuid
  clientTenantId   String       @db.Uuid
  clientTenant     ClientTenant @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  entityId         String       @db.Uuid
  entity           Entity       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  participantType  ObjectType
  participantId    String       @db.Uuid
  roleLabel        String       @db.VarChar(80)
  ownershipPercent Decimal?     @db.Decimal(6, 3)
  effectiveFrom    DateTime?    @db.Date
  effectiveUntil   DateTime?    @db.Date
  sourceDocumentId String?      @db.Uuid
  createdAt        DateTime     @default(now())

  @@index([clientTenantId])
  @@index([entityId])
  @@map("entity_participants")
}

model Asset {
  id             String       @id @default(uuid()) @db.Uuid
  clientTenantId String       @db.Uuid
  clientTenant   ClientTenant @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  entityId       String?      @db.Uuid
  entity         Entity?      @relation(fields: [entityId], references: [id], onDelete: SetNull)
  assetType      AssetType
  name           String       @db.VarChar(180)
  jurisdiction   String?      @db.VarChar(80)
  currency       String?      @db.VarChar(3)
  valueBand      String?      @db.VarChar(80)
  estimatedValue Decimal?     @db.Decimal(18, 2)
  valuationDate  DateTime?    @db.Date
  riskRating     String?      @db.VarChar(40)
  status         String       @db.VarChar(40)
  sensitivity    Sensitivity
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([clientTenantId])
  @@index([entityId])
  @@map("assets")
}

model Document {
  id               String               @id @default(uuid()) @db.Uuid
  clientTenantId   String               @db.Uuid
  clientTenant     ClientTenant         @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  engagementId     String?              @db.Uuid
  engagement       Engagement?          @relation(fields: [engagementId], references: [id], onDelete: SetNull)
  uploadedByUserId String               @db.Uuid
  documentType     String               @db.VarChar(100)
  title            String               @db.VarChar(220)
  status           DocumentStatus
  fileName         String?              @db.VarChar(260)
  mimeType         String?              @db.VarChar(120)
  fileSizeBytes    Int?
  storageKey       String?              @db.VarChar(500)
  checksum         String?              @db.VarChar(128)
  source           String?              @db.VarChar(80)
  sensitivity      Sensitivity
  clientVisible    Boolean              @default(false)
  retentionPolicy  String?              @db.VarChar(120)
  expiresAt        DateTime?            @db.Date
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  versions         DocumentVersion[]
  extractions      DocumentExtraction[]
  reviews          DocumentReview[]
  links            DocumentLink[]
  generatedExports ExportRequest[]

  @@index([clientTenantId, status])
  @@index([engagementId])
  @@map("documents")
}

model DocumentVersion {
  id              String   @id @default(uuid()) @db.Uuid
  documentId      String   @db.Uuid
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber   Int
  storageKey      String   @db.VarChar(500)
  checksum        String?  @db.VarChar(128)
  createdByUserId String   @db.Uuid
  changeReason    String?  @db.Text
  createdAt       DateTime @default(now())

  @@unique([documentId, versionNumber])
  @@map("document_versions")
}

model DocumentExtraction {
  id                      String   @id @default(uuid()) @db.Uuid
  documentId              String   @db.Uuid
  document                Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  extractionStatus        String   @db.VarChar(60)
  confidenceScore         Decimal? @db.Decimal(5, 2)
  extractedFieldsJson     Json?
  lowConfidenceFieldsJson Json?
  modelVersion            String?  @db.VarChar(80)
  isClientVisible         Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([documentId])
  @@map("document_extractions")
}

model DocumentReview {
  id                   String       @id @default(uuid()) @db.Uuid
  documentId           String       @db.Uuid
