  @@index([clientTenantId, status])
  @@index([targetType, targetId])
  @@map("review_schedules")
}

model MessageThread {
  id                String               @id @default(uuid()) @db.Uuid
  clientTenantId    String               @db.Uuid
  clientTenant      ClientTenant         @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  engagementId      String?              @db.Uuid
  engagement        Engagement?          @relation(fields: [engagementId], references: [id], onDelete: SetNull)
  subject           String               @db.VarChar(220)
  channel           CommunicationChannel
  status            WorkflowStatus
  clientVisible     Boolean              @default(false)
  relatedObjectType ObjectType?
  relatedObjectId   String?              @db.Uuid
  createdByUserId   String               @db.Uuid
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  messages          Message[]

  @@index([clientTenantId, status])
  @@map("message_threads")
}

model Message {
  id               String        @id @default(uuid()) @db.Uuid
  threadId         String        @db.Uuid
  thread           MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUserId     String        @db.Uuid
  body             String        @db.Text
  clientVisible    Boolean       @default(false)
  requiresApproval Boolean       @default(false)
  approvalId       String?       @db.Uuid
  sentAt           DateTime?
  createdAt        DateTime      @default(now())

  @@index([threadId])
  @@map("messages")
}

model CallEvent {
  id                String         @id @default(uuid()) @db.Uuid
  clientTenantId    String         @db.Uuid
  clientTenant      ClientTenant   @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  engagementId      String?        @db.Uuid
  engagement        Engagement?    @relation(fields: [engagementId], references: [id], onDelete: SetNull)
  relatedObjectType ObjectType?
  relatedObjectId   String?        @db.Uuid
  escalationType    EscalationType
  scheduledByUserId String         @db.Uuid
  scheduledFor      DateTime?
  durationMinutes   Int?
  status            WorkflowStatus
  outcomeSummary    String?        @db.Text
  evidenceRecordId  String?        @db.Uuid
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([clientTenantId, status])
  @@map("call_events")
}

model ExportRequest {
  id                      String       @id @default(uuid()) @db.Uuid
  clientTenantId          String       @db.Uuid
  clientTenant            ClientTenant @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  requestedByUserId       String       @db.Uuid
  exportType              ExportType
  status                  ExportStatus
  scopeJson               Json
  redactionProfile        String       @db.VarChar(80)
  approvalRequired        Boolean      @default(false)
  approvedByUserId        String?      @db.Uuid
  generatedFileDocumentId String?      @db.Uuid
  generatedFileDocument   Document?    @relation(fields: [generatedFileDocumentId], references: [id], onDelete: SetNull)
  expiresAt               DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  @@index([clientTenantId, status])
  @@map("export_requests")
}

model PolicyDefinition {
  id               String         @id @default(uuid()) @db.Uuid
  platformTenantId String         @db.Uuid
  platformTenant   PlatformTenant @relation(fields: [platformTenantId], references: [id], onDelete: Restrict)
  clientTenantId   String?        @db.Uuid
  clientTenant     ClientTenant?  @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  policyKey        String         @db.VarChar(140)
  name             String         @db.VarChar(180)
  version          String         @db.VarChar(40)
  category         String         @db.VarChar(80)
  rulesJson        Json
  status           String         @db.VarChar(40)
  createdByUserId  String         @db.Uuid
  effectiveFrom    DateTime?      @db.Date
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([platformTenantId, clientTenantId, policyKey, version])
  @@index([clientTenantId])
  @@map("policy_definitions")
}

model QueueItem {
  id               String         @id @default(uuid()) @db.Uuid
  clientTenantId   String         @db.Uuid
  clientTenant     ClientTenant   @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  queueName        String         @db.VarChar(120)
  targetType       ObjectType
  targetId         String         @db.Uuid
  assignedToUserId String?        @db.Uuid
  assignedRoleKey  String?        @db.VarChar(120)
  priority         String         @db.VarChar(40)
  status           WorkflowStatus
  slaDueAt         DateTime?
  escalated        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([clientTenantId, queueName])
  @@index([status, slaDueAt])
  @@map("queue_items")
}

model DataQualityIssue {
  id             String         @id @default(uuid()) @db.Uuid
  clientTenantId String         @db.Uuid
  clientTenant   ClientTenant   @relation(fields: [clientTenantId], references: [id], onDelete: Cascade)
  targetType     ObjectType
  targetId       String         @db.Uuid
  severity       String         @db.VarChar(40)
  issueType      String         @db.VarChar(100)
  description    String         @db.Text
  status         WorkflowStatus
  ownerUserId    String?        @db.Uuid
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([clientTenantId, status])
  @@index([targetType, targetId])
  @@map("data_quality_issues")
}
