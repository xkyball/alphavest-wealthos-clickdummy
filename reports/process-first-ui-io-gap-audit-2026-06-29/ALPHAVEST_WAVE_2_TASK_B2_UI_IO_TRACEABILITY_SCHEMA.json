  "downgrade_rules": [
    {
      "id": "DR-001",
      "if": "route_touchpoints present but ui_inputs and ui_outputs are absent",
      "then": "ui_representation_state=specified_only and acceptance_state cannot be implemented"
    },
    {
      "id": "DR-002",
      "if": "component exists but no bound input/output/action evidence exists",
      "then": "ui_representation_state=visible_only"
    },
    {
      "id": "DR-003",
      "if": "UI action exists but service_backing_state is none/read_only/mock_or_seeded",
      "then": "ui_representation_state=actionable_ui_only or actionable_with_blockers"
    },
    {
      "id": "DR-004",
      "if": "output exists only in modal/local copy",
      "then": "ui_output_status=modal_local and acceptance_state cannot be implemented"
    },
    {
      "id": "DR-005",
      "if": "safety_sensitive=true and negative_proof_status is missing/planned/stale",
      "then": "acceptance_state cannot be implemented and gap_priority at least P1"
    },
    {
      "id": "DR-006",
      "if": "client-facing route lacks client_safe_projection proof",
      "then": "gap_priority=P0 when internal payload leakage is possible"
    },
    {
      "id": "DR-007",
      "if": "audit_or_evidence_status is missing for sensitive command",
      "then": "acceptance_state cannot be implemented"
    },
    {
      "id": "DR-008",
      "if": "selected object continuity is not proven for mutation",
      "then": "missing_layers includes missing_selected_object_continuity"
    }
  ],
  "validation_rules": [
    "File must contain exactly 438 rows unless an explicit retained_step_exclusion register exists.",
    "Every row must have non-empty process_id and step_id.",
    "Every step_id must be unique.",
    "Every row must include at least one required_input or mark ui_input_status as not_required with rationale.",
    "Every row must include at least one expected_output or mark ui_output_status as not_required with rationale.",
    "Every safety_sensitive row must include negative_proof_status and required negative proof refs or missing_negative_proof.",
    "No row may be marked implemented if route_only_overclaim, component_only_overclaim or screenshot_only_overclaim is present.",
    "No row may be marked implemented if service_backing_state is none/read_only/mock_or_seeded for a mutation step.",
    "No row may be marked implemented if audit_or_evidence_status is missing for a sensitive action.",
    "Gap summary must count missing_layers and gap_priority across all rows."
  ],
